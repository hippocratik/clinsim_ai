# Base URL of the backend (no trailing slash, no /api).
# Used when NEXT_PUBLIC_API_MODE=real.
NEXT_PUBLIC_API_URL=http://localhost:8000

# "real" = use FastAPI backend; "mock" or unset = use in-memory mock.
# After changing this file, restart `npm run dev` for values to take effect.
NEXT_PUBLIC_API_MODE=real
